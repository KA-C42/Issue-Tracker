    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.3",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.0",
    "nodemon": "^3.1.11",
    "supertest": "^7.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
